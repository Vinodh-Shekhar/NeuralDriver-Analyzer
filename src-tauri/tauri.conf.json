{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FrameBench Analyzer",
  "version": "1.0.4",
  "identifier": "com.framebench.analyzer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FrameBench Analyzer",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0MDdGNjI5MjEwMzVEQUMKUldTc1hRTWhLZllITkFEVldqcDFrV25Bd2trcDdLYndwN01NcmdMd2VTa003RFYrWVMrODRGazMK",
      "endpoints": [
        "https://github.com/Vinodh-Shekhar/FrameBench-Analyzer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
